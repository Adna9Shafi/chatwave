# ═══════════════════════════════════════════════════════════════
# ChatWave — Environment Variables
# ═══════════════════════════════════════════════════════════════
# Copy this file to .env.local and fill in your values.
# Never commit .env.local to version control.
# ═══════════════════════════════════════════════════════════════

# ─── MongoDB ───────────────────────────────────────────────────
# Connection string for MongoDB (Atlas or local).
# Local: mongodb://localhost:27017/chatwave
# Atlas: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/chatwave
MONGODB_URI=mongodb://localhost:27017/chatwave

# ─── NextAuth (Authentication) ────────────────────────────────
# Secret key for encrypting JWT tokens.
# Generate: openssl rand -base64 32
# WARNING: Use a strong, unique secret in production!
NEXTAUTH_SECRET=your-secret-key-change-in-production

# Full URL of your application (required by NextAuth).
# Development: http://localhost:3000
# Production: https://yourdomain.com
NEXTAUTH_URL=http://localhost:3000

# ─── Google OAuth 2.0 (Optional) ──────────────────────────────
# Get these from Google Cloud Console → APIs & Services → Credentials
# https://console.cloud.google.com/apis/credentials
# Leave empty to disable Google login.
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ─── Cloudinary (File Uploads) ────────────────────────────────
# Get these from Cloudinary Dashboard → Account Details.
# Free tier: 25GB storage, 20GB bandwidth.
# https://cloudinary.com/console
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# ─── Socket.io ─────────────────────────────────────────────────
# URL of the Socket.io server.
# Development (local): http://localhost:3001
# Production (Railway): https://your-app.up.railway.app
# Production (Render):  https://your-app.onrender.com
# Leave empty to default to http://localhost:3001
NEXT_PUBLIC_SOCKET_URL=http://localhost:3001

# ─── Environment ───────────────────────────────────────────────
# Set to 'production' in production environments.
# Auto-detected by Next.js when running `next build` + `next start`.
NODE_ENV=development
